menu "Smart Cooking App"

    config SMART_COOKING_MQTT_BROKER_URI
        string "MQTT Broker URI"
        default "mqtt://192.168.1.100:1883"
        help
            URI of the MQTT broker, e.g. mqtt://192.168.1.100:1883

    config SMART_COOKING_STABILITY_TEST
        bool "Enable stability test diagnostics"
        default n
        help
            When enabled, tasks log stack high-watermark every 30 seconds,
            and control_task also logs heap statistics. Intended for
            stability testing only — do not enable in production builds.

    config SMART_COOKING_CLI
        bool "Enable UART CLI for manual command injection"
        default n
        help
            When enabled, a lightweight CLI task reads single-character
            commands from UART0 (the serial monitor port) and injects them
            into the control command queue. Intended for M3 hardware testing
            before MQTT commands are available. Do not enable in production.

    config SMART_COOKING_FAULT_INJECT
        bool "Enable fault injection overrides for testing"
        default n
        help
            Lowers Profile 0 safety_cutoff to 30 °C and reduces
            HEAT_RISE_MS to 15 s so FAULT_OVERTEMP and
            FAULT_HEATER_FAIL can be tested without real heating hardware.
            Must never be enabled in production builds.

endmenu
